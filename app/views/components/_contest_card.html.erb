<article class="card flex flex-col h-full">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <p class="text-xs text-gray-500 truncate"><%= contest.match.matchup %></p>
      <h3 class="mt-0.5 text-base font-semibold text-gray-900 leading-snug"><%= contest.name %></h3>
    </div>
    <span class="badge <%= status_class(contest.status) %> flex-shrink-0"><%= contest.status.humanize %></span>
  </div>

  <div class="mt-4 flex items-center justify-between gap-2 text-sm">
    <div class="flex-1 min-w-0">
      <p class="text-xs text-gray-500">Entry</p>
      <p class="mt-0.5 font-mono font-semibold text-gray-900 text-sm truncate"><%= money(contest.entry_fee) %></p>
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-xs text-gray-500">Prize Pool</p>
      <p class="mt-0.5 font-mono font-semibold text-green-600 text-sm truncate"><%= money(contest.prize_pool) %></p>
    </div>
    <div class="flex-shrink-0 text-right">
      <p class="text-xs text-gray-500">Winners</p>
      <p class="mt-0.5 font-mono font-semibold text-gray-900 text-sm"><%= contest.winner_count %></p>
    </div>
  </div>

  <div class="mt-4">
    <div class="flex justify-between text-xs text-gray-500">
      <span><%= contest.filled_spots %>/<%= contest.total_spots %> spots</span>
      <span><%= contest.progress_percentage %>%</span>
    </div>
    <div class="progress-bar mt-1.5">
      <div class="progress-bar-fill" style="width: <%= contest.progress_percentage %>%"></div>
    </div>
  </div>

  <div class="mt-auto pt-4 flex items-center justify-between gap-2">
    <span class="badge badge-muted text-xs"><%= contest_type_label(contest) %></span>
    <% if contest.user_teams.exists?(user: current_user) %>
      <%= link_to "View Team", contest_path(contest), class: "btn-secondary text-sm px-3" %>
    <% elsif contest.joinable? && !contest.match.locked? %>
      <%= link_to "Join", new_contest_team_path(contest), class: "btn-primary text-sm px-4" %>
    <% else %>
      <span class="text-xs text-gray-400 font-medium">Entry closed</span>
    <% end %>
  </div>
</article>
