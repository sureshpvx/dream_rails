<article class="card flex h-full flex-col justify-between">
  <div>
    <div class="flex items-center justify-between gap-3">
      <span class="badge <%= status_class(match.status) %>"><%= match.status.humanize %></span>
      <span class="text-xs text-gray-500"><%= match.format %></span>
    </div>

    <div class="mt-5 grid grid-cols-[1fr_auto_1fr] items-center gap-3">
      <div class="text-center">
        <div class="team-mark team-a"><%= match.team_a_short %></div>
        <p class="mt-3 text-sm font-semibold text-gray-900"><%= match.team_a_short %></p>
      </div>
      <span class="text-sm font-semibold text-gray-400">VS</span>
      <div class="text-center">
        <div class="team-mark team-b"><%= match.team_b_short %></div>
        <p class="mt-3 text-sm font-semibold text-gray-900"><%= match.team_b_short %></p>
      </div>
    </div>

    <p class="mt-5 font-semibold text-gray-900"><%= match.team_a %> vs <%= match.team_b %></p>
    <p class="mt-2 text-sm text-gray-500"><%= match.match_date.strftime("%b %-d, %Y at %l:%M %p") %></p>
    <p class="mt-1 text-sm text-gray-500"><%= match.venue %></p>
  </div>

  <div class="mt-5 flex items-center justify-between gap-3 border-t border-gray-200 pt-4">
    <span class="text-sm text-gray-500"><%= pluralize(match.contests.size, "contest") %></span>
    <%= link_to "Open", match_path(match), class: "btn-secondary" %>
  </div>
</article>
