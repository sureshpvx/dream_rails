<% content_for :title, "Wallet - DreamRails" %>

<section class="space-y-6">
  <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 p-6">
    <p class="text-sm font-semibold text-emerald-200">Virtual wallet</p>
    <h1 class="mt-2 font-mono text-4xl font-bold text-emerald-100"><%= money(current_user.virtual_balance) %></h1>
    <p class="mt-3 max-w-2xl text-sm text-slate-300">Play money only. Coins cannot be deposited, withdrawn, sold, or redeemed.</p>
  </div>

  <section>
    <h2 class="mb-3 text-xl font-semibold">Transactions</h2>
    <% if @transactions.any? %>
      <div class="overflow-hidden rounded-lg border border-slate-800">
        <table class="w-full min-w-[42rem] divide-y divide-slate-800 bg-slate-900 text-left text-sm">
          <thead class="bg-slate-950 text-slate-400">
            <tr>
              <th class="px-4 py-3">Date</th>
              <th class="px-4 py-3">Type</th>
              <th class="px-4 py-3">Description</th>
              <th class="px-4 py-3 text-right">Amount</th>
              <th class="px-4 py-3 text-right">Balance</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            <% @transactions.each do |transaction| %>
              <tr>
                <td class="px-4 py-3 text-slate-400"><%= transaction.created_at.strftime("%b %-d, %Y") %></td>
                <td class="px-4 py-3"><span class="badge badge-muted"><%= transaction.transaction_type.humanize %></span></td>
                <td class="px-4 py-3"><%= transaction.description %></td>
                <td class="px-4 py-3 text-right font-mono <%= transaction.amount.positive? ? "text-emerald-300" : "text-red-300" %>"><%= money(transaction.amount) %></td>
                <td class="px-4 py-3 text-right font-mono"><%= money(transaction.balance_after) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "No transactions yet", body: "Your play money activity will show up here." %>
    <% end %>
  </section>
</section>
