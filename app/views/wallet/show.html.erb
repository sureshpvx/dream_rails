<% content_for :title, "Wallet - DreamRails" %>

<section class="space-y-6">
  <div class="wallet-banner">
    <p class="text-sm font-semibold text-green-700">Virtual wallet</p>
    <h1 class="mt-2 font-mono text-4xl font-bold text-green-800"><%= money(current_user.virtual_balance) %></h1>
    <p class="mt-3 max-w-2xl text-sm text-gray-600">Play money only. Coins cannot be deposited, withdrawn, sold, or redeemed.</p>
  </div>

  <section>
    <h2 class="mb-3 text-xl font-semibold text-gray-900">Transactions</h2>
    <% if @transactions.any? %>
      <div class="table-container">
        <table class="w-full min-w-[42rem]">
          <thead>
            <tr>
              <th class="px-4 py-3">Date</th>
              <th class="px-4 py-3">Type</th>
              <th class="px-4 py-3">Description</th>
              <th class="px-4 py-3 text-right">Amount</th>
              <th class="px-4 py-3 text-right">Balance</th>
            </tr>
          </thead>
          <tbody>
            <% @transactions.each do |transaction| %>
              <tr>
                <td class="text-gray-500"><%= transaction.created_at.strftime("%b %-d, %Y") %></td>
                <td><span class="badge badge-muted"><%= transaction.transaction_type.humanize %></span></td>
                <td class="text-gray-700"><%= transaction.description %></td>
                <td class="text-right font-mono <%= transaction.amount.positive? ? "text-green-600" : "text-red-600" %>"><%= money(transaction.amount) %></td>
                <td class="text-right font-mono text-gray-900"><%= money(transaction.balance_after) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "No transactions yet", body: "Your play money activity will show up here." %>
    <% end %>
  </section>
</section>
