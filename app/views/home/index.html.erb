<% content_for :title, "DreamRails" %>

<section class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_22rem]">
  <div class="space-y-6">
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-sm font-semibold text-green-600">Build Your Dream Team. Win Virtual Glory.</p>
          <h1 class="mt-2 text-3xl font-bold text-gray-900 sm:text-4xl">DreamRails fantasy cricket</h1>
          <p class="mt-3 max-w-2xl text-gray-600">Play-money contests, live leaderboards, squad budgets, and fantasy points built around real cricket rules.</p>
        </div>
        <div class="wallet-banner">
          <p class="text-sm text-gray-600">Virtual balance</p>
          <p class="mt-1 font-mono text-2xl font-bold text-green-700"><%= money(current_user.virtual_balance) %></p>
        </div>
      </div>
    </div>

    <% if @featured_match %>
      <section>
        <div class="mb-3 flex items-center justify-between">
          <h2 class="text-xl font-semibold text-gray-900">Featured Match</h2>
          <%= link_to "All matches", matches_path, class: "text-sm font-semibold text-green-600 hover:text-green-700" %>
        </div>
        <%= render "components/match_card", match: @featured_match %>
      </section>
    <% end %>

    <section>
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-xl font-semibold text-gray-900">Open Contests</h2>
        <%= link_to "Browse contests", contests_path, class: "text-sm font-semibold text-green-600 hover:text-green-700" %>
      </div>
      <% if @contests.any? %>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          <%= render partial: "components/contest_card", collection: @contests, as: :contest %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No contests available", body: "Seed the app to load upcoming fantasy cricket contests." %>
      <% end %>
    </section>

    <section>
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-xl font-semibold text-gray-900">Upcoming Matches</h2>
        <%= link_to "Matches", matches_path, class: "text-sm font-semibold text-green-600 hover:text-green-700" %>
      </div>
      <% if @matches.any? %>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          <%= render partial: "components/match_card", collection: @matches, as: :match %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No matches right now", body: "Check back later for upcoming cricket action." %>
      <% end %>
    </section>
  </div>

  <aside class="space-y-6">
    <section class="card">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">Leaderboard</h2>
        <%= link_to "Full", leaderboard_path, class: "text-sm font-semibold text-green-600 hover:text-green-700" %>
      </div>
      <div class="mt-4 space-y-3">
        <% @leaderboard.each_with_index do |team, index| %>
          <div class="flex items-center justify-between rounded-lg bg-gray-50 p-3">
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= index + 1 %>. <%= team.user.username %></p>
              <p class="text-xs text-gray-500"><%= team.contest.name %></p>
            </div>
            <p class="font-mono font-semibold text-gray-900"><%= team.total_points %></p>
          </div>
        <% end %>
        <% if @leaderboard.empty? %>
          <p class="text-sm text-gray-500">No submitted teams yet.</p>
        <% end %>
      </div>
    </section>

    <section class="card">
      <h2 class="text-lg font-semibold text-gray-900">Play-Money Notice</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">All coins in DreamRails are virtual and have zero monetary value. Real deposits and withdrawals are intentionally unavailable.</p>
    </section>
  </aside>
</section>
