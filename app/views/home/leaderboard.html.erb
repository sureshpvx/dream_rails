<% content_for :title, "Leaderboard - DreamRails" %>

<section class="space-y-4">
  <div>
    <p class="text-sm font-semibold text-green-600">Global standings</p>
    <h1 class="mt-2 text-3xl font-bold text-gray-900">Leaderboard</h1>
  </div>

  <div class="table-container">
    <table class="w-full min-w-[42rem]">
      <thead>
        <tr>
          <th class="px-4 py-3">Rank</th>
          <th class="px-4 py-3">User</th>
          <th class="px-4 py-3">Team</th>
          <th class="px-4 py-3">Contest</th>
          <th class="px-4 py-3 text-right">Points</th>
          <th class="px-4 py-3 text-right">Prize</th>
        </tr>
      </thead>
      <tbody>
        <% @leaderboard.each_with_index do |team, index| %>
          <tr class="<%= "highlight-row" if team.user_id == current_user.id %>">
            <td class="px-4 py-3 font-mono"><%= team.rank || index + 1 %></td>
            <td class="px-4 py-3 font-semibold"><%= team.user.username %></td>
            <td class="px-4 py-3"><%= link_to team.team_name, user_team_path(team), class: "text-green-600 hover:text-green-700" if team.user_id == current_user.id %><%= team.team_name unless team.user_id == current_user.id %></td>
            <td class="px-4 py-3 text-gray-500"><%= team.contest.name %></td>
            <td class="px-4 py-3 text-right font-mono"><%= team.total_points %></td>
            <td class="px-4 py-3 text-right font-mono text-green-600"><%= money(team.prize_won) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
