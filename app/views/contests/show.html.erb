<% content_for :title, "#{@contest.name} - DreamRails" %>

<section class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_22rem]">
  <div class="space-y-6">
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="text-sm font-semibold text-green-600"><%= link_to @contest.match.matchup, match_path(@contest.match) %></p>
          <h1 class="mt-2 text-3xl font-bold text-gray-900"><%= @contest.name %></h1>
          <p class="mt-2 text-gray-500"><%= @contest.match.venue %> &middot; <%= @contest.match.match_date.strftime("%b %-d, %l:%M %p") %></p>
        </div>
        <span class="badge <%= status_class(@contest.status) %>"><%= @contest.status.humanize %></span>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-4">
        <div class="stat-card">
          <p class="text-sm text-gray-500">Entry</p>
          <p class="mt-1 font-mono text-xl font-semibold text-gray-900"><%= money(@contest.entry_fee) %></p>
        </div>
        <div class="stat-card">
          <p class="text-sm text-gray-500">Prize pool</p>
          <p class="mt-1 font-mono text-xl font-semibold text-green-600"><%= money(@contest.prize_pool) %></p>
        </div>
        <div class="stat-card">
          <p class="text-sm text-gray-500">Spots left</p>
          <p class="mt-1 font-mono text-xl font-semibold text-gray-900"><%= @contest.spots_left %></p>
        </div>
        <div class="stat-card">
          <p class="text-sm text-gray-500">Winners</p>
          <p class="mt-1 font-mono text-xl font-semibold text-gray-900"><%= @contest.winner_count %></p>
        </div>
      </div>

      <div class="mt-6">
        <div class="flex justify-between text-sm text-gray-500">
          <span><%= @contest.filled_spots %>/<%= @contest.total_spots %> spots</span>
          <span><%= @contest.progress_percentage %>% filled</span>
        </div>
        <div class="progress-bar mt-2" style="height: 0.75rem;">
          <div class="progress-bar-fill" style="width: <%= @contest.progress_percentage %>%"></div>
        </div>
      </div>

      <div class="mt-6">
        <% if @user_team %>
          <%= link_to "View my team", user_team_path(@user_team), class: "btn-primary" %>
        <% elsif @contest.joinable? && !@contest.match.locked? %>
          <%= link_to "Create team", new_contest_team_path(@contest), class: "btn-primary" %>
        <% else %>
          <span class="badge badge-muted">Team entry closed</span>
        <% end %>
      </div>
    </div>

    <section>
      <h2 class="mb-3 text-xl font-semibold text-gray-900">Leaderboard</h2>
      <% if @leaderboard.any? %>
        <div class="table-container">
          <table class="w-full min-w-[34rem]">
            <thead>
              <tr>
                <th class="px-4 py-3">Rank</th>
                <th class="px-4 py-3">User</th>
                <th class="px-4 py-3">Team</th>
                <th class="px-4 py-3 text-right">Points</th>
              </tr>
            </thead>
            <tbody>
              <% @leaderboard.each_with_index do |team, index| %>
                <tr class="<%= "highlight-row" if team.user_id == current_user.id %>">
                  <td class="px-4 py-3 font-mono"><%= team.rank || index + 1 %></td>
                  <td class="px-4 py-3 font-semibold"><%= team.user.username %></td>
                  <td class="px-4 py-3"><%= team.team_name %></td>
                  <td class="px-4 py-3 text-right font-mono"><%= team.total_points %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No teams yet", body: "Join this contest and build your dream team." %>
      <% end %>
    </section>
  </div>

  <aside class="space-y-4">
    <div class="card">
      <h2 class="text-lg font-semibold text-gray-900">Prize Rules</h2>
      <dl class="mt-4 space-y-3 text-sm">
        <div class="flex justify-between gap-3"><dt class="text-gray-500">Type</dt><dd class="text-gray-900"><%= contest_type_label(@contest) %></dd></div>
        <div class="flex justify-between gap-3"><dt class="text-gray-500">Platform fee</dt><dd class="text-gray-900"><%= @contest.platform_fee_percentage %>%</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-gray-500">Guaranteed</dt><dd class="text-gray-900"><%= @contest.guaranteed_prize? ? "Yes" : "No" %></dd></div>
      </dl>
    </div>
  </aside>
</section>
