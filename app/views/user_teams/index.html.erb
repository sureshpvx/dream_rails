<% content_for :title, "My Teams - DreamRails" %>

<section class="space-y-5">
  <div>
    <p class="text-sm font-semibold text-emerald-300"><%= current_user.username %></p>
    <h1 class="mt-2 text-3xl font-bold">My Teams</h1>
  </div>

  <% if @user_teams.any? %>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% @user_teams.each do |team| %>
        <article class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm text-slate-400"><%= team.match.matchup %></p>
              <h2 class="mt-1 text-lg font-semibold"><%= team.team_name %></h2>
            </div>
            <span class="badge <%= status_class(team.status) %>"><%= team.status.humanize %></span>
          </div>
          <div class="mt-5 grid grid-cols-3 gap-3 text-sm">
            <div><p class="text-slate-500">Points</p><p class="mt-1 font-mono font-semibold"><%= team.total_points %></p></div>
            <div><p class="text-slate-500">Rank</p><p class="mt-1 font-mono font-semibold"><%= team.rank || "-" %></p></div>
            <div><p class="text-slate-500">Prize</p><p class="mt-1 font-mono font-semibold"><%= money(team.prize_won) %></p></div>
          </div>
          <div class="mt-5 flex justify-between gap-3 border-t border-slate-800 pt-4">
            <span class="text-sm text-slate-400"><%= team.contest.name %></span>
            <%= link_to "Open", user_team_path(team), class: "btn-secondary" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No teams yet", body: "Join a contest and build your dream team." %>
  <% end %>
</section>
