<aside class="fixed bottom-0 left-0 top-0 z-20 hidden w-64 border-r border-gray-200 bg-white px-4 pt-24 lg:block">
  <nav class="space-y-2">
    <%= link_to "Home", root_path, class: active_link_class(root_path, "sidebar-link") %>
    <%= link_to "Matches", matches_path, class: active_link_class(matches_path, "sidebar-link") %>
    <%= link_to "Contests", contests_path, class: active_link_class(contests_path, "sidebar-link") %>
    <%= link_to "My Teams", user_teams_path, class: active_link_class(user_teams_path, "sidebar-link") %>
    <%= link_to "Wallet", wallet_path, class: active_link_class(wallet_path, "sidebar-link") %>
    <%= link_to "Leaderboard", leaderboard_path, class: active_link_class(leaderboard_path, "sidebar-link") %>
    <%= link_to notifications_path, class: active_link_class(notifications_path, "sidebar-link flex items-center justify-between") do %>
      <span>Notifications</span>
      <% if unread_notification_count > 0 %>
        <span class="rounded-full bg-red-500 px-2 py-0.5 text-xs font-bold text-white"><%= unread_notification_count %></span>
      <% end %>
    <% end %>
  </nav>

  <div class="mt-8 rounded-lg border border-gray-200 bg-gray-50 p-4">
    <p class="text-xs uppercase text-gray-500">Signed in as</p>
    <p class="mt-1 font-semibold text-gray-900"><%= current_user.display_name %></p>
    <p class="mt-2 text-sm text-gray-500">18+ only. Virtual coins have no monetary value.</p>
  </div>
</aside>
