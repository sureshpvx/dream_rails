<header class="fixed inset-x-0 top-0 z-30 border-b border-gray-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:pl-72 lg:pr-8">
    <%= link_to root_path, class: "flex items-center gap-3" do %>
      <span class="grid h-10 w-10 place-items-center rounded-lg bg-green-600 font-black text-white">DR</span>
      <span>
        <span class="block text-lg font-bold leading-5 text-gray-900">DreamRails</span>
        <span class="block text-xs text-gray-500">Play-money fantasy cricket</span>
      </span>
    <% end %>

    <nav class="hidden items-center gap-1 md:flex">
      <%= link_to "Matches", matches_path, class: "nav-link" %>
      <%= link_to "Contests", contests_path, class: "nav-link" %>
      <%= link_to "Leaderboard", leaderboard_path, class: "nav-link" %>
    </nav>

    <div class="flex items-center gap-3">
      <%= link_to notifications_path, class: "relative p-2 rounded-lg hover:bg-gray-100 text-gray-600" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
        </svg>
        <% if unread_notification_count > 0 %>
          <span class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs font-bold text-white">
            <%= unread_notification_count > 9 ? "9+" : unread_notification_count %>
          </span>
        <% end %>
      <% end %>

      <%= link_to wallet_path, class: "rounded-lg border border-green-200 bg-green-50 px-3 py-2 text-sm font-semibold text-green-700" do %>
        <span class="text-gray-500">Wallet</span>
        <span class="ml-2 font-mono"><%= money(current_user.virtual_balance) %></span>
      <% end %>
    </div>
  </div>
</header>
